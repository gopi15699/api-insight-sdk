PORT=5001
# Note: port 5000 is reserved by macOS AirPlay/Control Center on macOS 12+
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/api-insight

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Alerts
ALERT_EMAIL_FROM=alerts@api-insight.com
ALERT_EMAIL_TO=admin@yourcompany.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Error threshold for alerts
ALERT_ERROR_THRESHOLD=10

# CORS
ALLOWED_ORIGINS=http://localhost:3000
